@page "/register"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@using global::Shared.Commands
@using Client.Services
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@layout AuthLayout

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center mud-width-full" Style="height: 100vh;">
    <MudPaper Elevation="3" Class="pa-8 w-100" Style="max-width: 450px;">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6">Registration</MudText>
        
        <MudForm @ref="_form" @bind-IsValid="@_success">
            <MudTextField @bind-Value="_model.FirstName" Label="Name" Required="true" Variant="Variant.Outlined" Class="mb-4" />
            <MudTextField @bind-Value="_model.LastName" Label="Surname" Required="true" Variant="Variant.Outlined" Class="mb-4" />
            <MudTextField @bind-Value="_model.UserName" Label="Login" Required="true" Variant="Variant.Outlined" Class="mb-4" />
            <MudTextField @bind-Value="_model.Password" Label="Password" Required="true" Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-6" />
            
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true" Disabled="@(!_success || _isLoading)" OnClick="HandleRegister">
                @if (_isLoading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Registration...</MudText>
                }
                else
                {
                    <MudText>Registered</MudText>
                }
            </MudButton>
        </MudForm>

        <div class="d-flex justify-center mt-4">
            <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="@(() => NavigationManager.NavigateTo("/login"))">
                Already registered? Login
            </MudButton>
        </div>
    </MudPaper>
</MudContainer>

@code {
    private MudForm _form = null!;
    private bool _success;
    private bool _isLoading;
    
    private RegisterFormModel _model = new();

    private class RegisterFormModel
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string UserName { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    private async Task HandleRegister()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _isLoading = true;
        try
        {
            var command = new RegisterUserCommand
            {
                // Имя и фамилию мы пока не передаем в команду, так как их нет в DTO
                UserName = _model.UserName, 
                Password = _model.Password,
                Role = "User" // Значение по умолчанию, если нужно
            };
            
            var success = await AuthService.RegisterAsync(command);
            if (success)
            {
                Snackbar.Add("Registered successfully! You can log in now.", Severity.Success);
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                Snackbar.Add("Error. Login is busy.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Server error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
